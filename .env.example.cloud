# ── PatientVectorHub — Cloud Development Environment ────────────────────────
# Copy this file to .env and fill in your cloud service endpoints
# NEVER commit the .env file — it is in .gitignore
#
# This template assumes:
# - PostgreSQL on cloud (AWS RDS, Azure Database, GCP Cloud SQL, etc.)
# - Redis on cloud (AWS ElastiCache, Azure Cache, GCP Memorystore, etc.)
# - Kafka on cloud (AWS MSK, Confluent Cloud, Aiven, etc.)
# - Weaviate on cloud (self-hosted EC2 or Weaviate Cloud)
# - Qdrant on cloud (self-hosted EC2 or Qdrant Cloud)
# - FastAPI running locally
# - Embedding server running locally

# ── Database ─────────────────────────────────────────────────────────────────
# AWS RDS example:
# DATABASE_URL=postgresql+asyncpg://pvh:password@my-db.c9akciq32.us-east-1.rds.amazonaws.com:5432/pvh
# Azure example:
# DATABASE_URL=postgresql+asyncpg://pvh:password@my-server.postgres.database.azure.com:5432/pvh
# GCP example:
# DATABASE_URL=postgresql+asyncpg://pvh:password@35.224.123.45:5432/pvh

DATABASE_URL=postgresql+asyncpg://pvh:YOUR_PASSWORD@your-db-host.rds.amazonaws.com:5432/pvh
DATABASE_URL_SYNC=postgresql+psycopg2://pvh:YOUR_PASSWORD@your-db-host.rds.amazonaws.com:5432/pvh

# ── Cache & Messaging ─────────────────────────────────────────────────────────
# AWS ElastiCache Redis:
# REDIS_URL=redis://your-redis-endpoint.abc123.ng.0001.use1.cache.amazonaws.com:6379/0
# With authentication:
# REDIS_URL=redis://:PASSWORD@your-redis-endpoint.abc123.ng.0001.use1.cache.amazonaws.com:6379/0
# Azure Cache for Redis:
# REDIS_URL=redis://:PASSWORD@your-redis.redis.cache.windows.net:6379/0
# GCP Memorystore:
# REDIS_URL=redis://10.0.0.2:6379/0

REDIS_URL=redis://your-redis-host.elasticache.amazonaws.com:6379/0

# AWS MSK (Managed Streaming for Kafka):
# KAFKA_BROKERS=b-1.kafka-cluster.abc123.kafka.us-east-1.amazonaws.com:9092,b-2.kafka-cluster.abc123.kafka.us-east-1.amazonaws.com:9092,b-3.kafka-cluster.abc123.kafka.us-east-1.amazonaws.com:9092
# Confluent Cloud:
# KAFKA_BROKERS=pkc-abc123.us-east-1.provider.confluent.cloud:9092
# With SASL/SSL:
# KAFKA_BROKERS=broker1:9092,broker2:9092,broker3:9092
# KAFKA_USERNAME=YOUR_USERNAME
# KAFKA_PASSWORD=YOUR_PASSWORD
# KAFKA_SECURITY_PROTOCOL=SASL_SSL

KAFKA_BROKERS=broker-1.abc123.kafka.us-east-1.amazonaws.com:9092,broker-2.abc123.kafka.us-east-1.amazonaws.com:9092,broker-3.abc123.kafka.us-east-1.amazonaws.com:9092

# ── Vector Stores ─────────────────────────────────────────────────────────────
# Weaviate on EC2:
# WEAVIATE_HOST=ec2-54-123-456-789.compute-1.amazonaws.com
# WEAVIATE_PORT=8080
# WEAVIATE_GRPC_PORT=50051
# Weaviate Cloud:
# WEAVIATE_HOST=your-cluster-id.weaviate.network
# WEAVIATE_PORT=443
# WEAVIATE_GRPC_PORT=443 (with gRPC over HTTPS)

VECTOR_BACKEND=weaviate
WEAVIATE_HOST=your-weaviate-ec2.us-east-1.compute.amazonaws.com
WEAVIATE_PORT=8080
WEAVIATE_GRPC_PORT=50051
WEAVIATE_URL=
WEAVIATE_API_KEY=

# Qdrant on EC2:
# QDRANT_HOST=ec2-54-987-654-321.compute-1.amazonaws.com
# QDRANT_PORT=6333
# Qdrant Cloud:
# QDRANT_HOST=your-cluster-name.qdrant.io
# QDRANT_PORT=6333 (or 443 for HTTPS)

QDRANT_HOST=your-qdrant-ec2.us-east-1.compute.amazonaws.com
QDRANT_PORT=6333
QDRANT_URL=
QDRANT_API_KEY=


# ── Embedding Model ───────────────────────────────────────────────────────────
# This runs on your LOCAL machine, NOT in the cloud
EMBEDDING_MODEL_URL=http://localhost:8001
EMBEDDING_MODEL_VERSION=clinical-bert-v2.1

# ── Vault ─────────────────────────────────────────────────────────────────────
# Self-hosted Vault on EC2:
# VAULT_ADDR=http://vault-ec2.us-east-1.compute.amazonaws.com:8200
# AWS Secrets Manager (if using instead):
# VAULT_ADDR=https://secretsmanager.us-east-1.amazonaws.com
# For development, you can use a dev token or skip it entirely

VAULT_ADDR=http://your-vault-ec2.us-east-1.compute.amazonaws.com:8200
VAULT_TOKEN=dev-root-token

# ── Keycloak ──────────────────────────────────────────────────────────────────
# Self-hosted Keycloak on EC2:
# KEYCLOAK_BASE_URL=http://keycloak-ec2.us-east-1.compute.amazonaws.com:8443
# Note: In development, you can use HTTP. In production, HTTPS is required.

KEYCLOAK_BASE_URL=http://your-keycloak-ec2.us-east-1.compute.amazonaws.com:8443
KEYCLOAK_REALM=patientvectorhub
KEYCLOAK_JWKS_URL=http://your-keycloak-ec2.us-east-1.compute.amazonaws.com:8443/realms/patientvectorhub/protocol/openid-connect/certs
KEYCLOAK_ISSUER=http://your-keycloak-ec2.us-east-1.compute.amazonaws.com:8443/realms/patientvectorhub
KEYCLOAK_CLIENT_ID=pvh-spa

# ── LLM Providers (REQUIRED — get from provider dashboards) ──────────────────
# Anthropic: https://console.anthropic.com/
# OpenAI: https://platform.openai.com/api-keys
# Google Gemini: https://aistudio.google.com/app/apikey

ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE
OPENAI_API_KEY=sk-YOUR_KEY_HERE
GEMINI_API_KEY=AIzaSyD_YOUR_KEY_HERE
LLM_DEFAULT_PROVIDER=anthropic
LLM_MAX_TOKENS=1000

# ── AWS (for S3 document storage) ─────────────────────────────────────────────
# AWS credentials loaded from ~/.aws/credentials or IAM role
# Buckets should be created in AWS S3 console before running

AWS_REGION=us-east-1
S3_DOCUMENT_BUCKET=pvh-documents-prod
S3_BACKUP_BUCKET=pvh-backups-prod

# ── Observability ─────────────────────────────────────────────────────────────
# Jaeger tracing (optional):
# JAEGER_ENDPOINT=http://jaeger-ec2.us-east-1.compute.amazonaws.com:4317
# DataDog/Grafana/Prometheus endpoints if using those instead

JAEGER_ENDPOINT=http://your-jaeger-ec2.us-east-1.compute.amazonaws.com:4317
LOG_LEVEL=DEBUG
ENVIRONMENT=development

# ── App ───────────────────────────────────────────────────────────────────────
# These control the local FastAPI server
API_HOST=0.0.0.0
API_PORT=8000

# CORS origins should include your dashboard URL(s)
# If dashboard is local: http://localhost:5173
# If dashboard is hosted: https://app.yourdomain.com
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://app.yourdomain.com

# ── Optional: SSL/TLS for Cloud Services ──────────────────────────────────────
# If your cloud services use SSL:
# DATABASE_URL=postgresql+asyncpg://pvh:password@host:5432/pvh?sslmode=require
# REDIS_URL=rediss://host:6379/0  (rediss = Redis with SSL)
# KAFKA_SECURITY_PROTOCOL=SASL_SSL  (if using SASL/SSL for Kafka)
# WEAVIATE_PORT=443  (if using HTTPS)
# QDRANT_PORT=443  (if using HTTPS)
#
# Add certificates/keys as needed for mutual TLS

# ── Optional: Network Configuration ───────────────────────────────────────────
# If your cloud services are in a private VPC:
# - Ensure your machine can reach them (VPN, bastion host, AWS SSM Session Manager, etc.)
# - Or use SSH tunneling to forward ports locally
#
# SSH tunnel example:
# ssh -i your-key.pem -L 5432:db-host:5432 ec2-user@bastion-host
# Then connect to localhost:5432

# ── Optional: Debugging ───────────────────────────────────────────────────────
# Enable detailed logging:
# LOG_LEVEL=DEBUG
#
# Enable query logging (PostgreSQL):
# DATABASE_LOG_LEVEL=DEBUG
#
# Enable Kafka debug logging:
# KAFKA_DEBUG=ALL
