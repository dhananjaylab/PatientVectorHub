# ── PatientVectorHub — Environment Variables ─────────────────────────────────
# Copy this file to .env and fill in your values before running make dev
# NEVER commit the .env file — it is in .gitignore

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://pvh:pvh_local@localhost:5432/pvh
DATABASE_URL_SYNC=postgresql+psycopg2://pvh:pvh_local@localhost:5432/pvh

# ── Cache & Messaging ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
KAFKA_BROKERS=localhost:9092

# ── Vector Stores ─────────────────────────────────────────────────────────────
VECTOR_BACKEND=weaviate
WEAVIATE_HOST=localhost
WEAVIATE_PORT=8080
WEAVIATE_GRPC_PORT=50051
QDRANT_HOST=localhost
QDRANT_PORT=6334

# ── Embedding Model ───────────────────────────────────────────────────────────
EMBEDDING_MODEL_URL=http://localhost:8001
EMBEDDING_MODEL_VERSION=clinical-bert-v2.1

# ── Vault ─────────────────────────────────────────────────────────────────────
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=dev-root-token
# In production: VAULT_TOKEN is NOT used — K8s ServiceAccount auth is used instead

# ── Keycloak ──────────────────────────────────────────────────────────────────
KEYCLOAK_BASE_URL=http://localhost:8443
KEYCLOAK_REALM=patientvectorhub
KEYCLOAK_JWKS_URL=http://localhost:8443/realms/patientvectorhub/protocol/openid-connect/certs
KEYCLOAK_ISSUER=http://localhost:8443/realms/patientvectorhub
KEYCLOAK_CLIENT_ID=pvh-spa

# ── LLM Providers (REQUIRED — get from provider dashboards) ──────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AIza...
LLM_DEFAULT_PROVIDER=anthropic
LLM_MAX_TOKENS=1000

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
S3_DOCUMENT_BUCKET=pvh-documents-dev
S3_BACKUP_BUCKET=pvh-backups-dev
# AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY loaded from ~/.aws/credentials
# or use IAM role (IRSA) in production

# ── Observability ─────────────────────────────────────────────────────────────
JAEGER_ENDPOINT=http://localhost:4317
LOG_LEVEL=DEBUG
ENVIRONMENT=development

# ── App ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
